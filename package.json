{
  "name": "orbittest",
  "version": "1.1.2",
  "description": "Browser automation test runner built on Chrome DevTools Protocol.",
  "main": "dist/orbit.js",
  "exports": {
    ".": "./dist/orbit.js"
  },
  "bin": {
    "orbittest": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "esbuild cli.js orbit.js --bundle --platform=node --format=cjs --packages=external --outdir=dist",
    "test": "node cli.js run",
    "prepack": "npm run build",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "browser-automation",
    "e2e",
    "testing",
    "test-runner",
    "chrome",
    "cdp"
  ],
  "author": "Abhay",
  "license": "Apache-2.0",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "puppeteer": "^24.42.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
